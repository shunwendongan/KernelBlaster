FROM nvcr.io/nvidia/pytorch:25.01-py3

WORKDIR /kernelblaster

# Add CUDA to PATH and set environment variables
ENV PATH=/usr/local/cuda/bin:${PATH}
ENV CUDA_HOME=/usr/local/cuda
ENV CUDACXX=/usr/local/cuda/bin/nvcc

# Verify CUDA installation
RUN nvcc --version

# Install only the dependencies used by the untrusted GPU worker. LLM and
# local-model packages remain in the control image.
COPY docker/requirements.gpu.txt /tmp/requirements.gpu.txt
RUN python -m pip install --no-cache-dir -U pip && \
    python -m pip install --no-cache-dir -r /tmp/requirements.gpu.txt

# Create an unprivileged runtime user with a real home directory.
RUN useradd --create-home --shell /bin/bash kernelblaster

# Copy the entire source code (filtered by .dockerignore)
COPY --chown=kernelblaster:kernelblaster . /kernelblaster/

# Create output directory
RUN mkdir -p /tmp/kernelblaster && \
    chown -R kernelblaster:kernelblaster /tmp/kernelblaster

# Switch to non-root user only at the end
USER kernelblaster

# Set environment variables for GPU execution
ENV CUDA_VISIBLE_DEVICES=0
ENV NVIDIA_TF32_OVERRIDE=0

# Expose the GPU server port
EXPOSE 2002

# Run the GPU server
CMD ["python", "scripts/start_gpu_worker.py", "--host", "127.0.0.1", "--port", "2002"]
