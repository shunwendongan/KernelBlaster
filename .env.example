# OpenAI-compatible Chat Completions endpoint. Never commit a real API key.
KERNELBLASTER_LLM_PROVIDER=openai_compatible
KERNELBLASTER_LLM_BASE_URL=https://your-gateway.example.com/v1
KERNELBLASTER_LLM_API_KEY=replace_with_your_api_key
MODEL=replace_with_your_gateway_model_id

# Provider controls
LLM_MAX_CONCURRENCY=4
LLM_MAX_RETRIES=3
LLM_REQUEST_TIMEOUT_SECONDS=1800
LLM_MAX_REQUESTS=0
LLM_MAX_TOTAL_TOKENS=0
LLM_MAX_COMPLETION_TOKENS=12288
# Optional for GPT-5.6 models: none, low, medium, high, xhigh, or max.
LLM_REASONING_EFFORT=low
STREAM=false

# Per-run control/worker authentication. The single-run script generates one
# automatically; set a fresh value explicitly when using docker/compose.worker.yml.
KERNELBLASTER_WORKER_TOKEN=
KERNELBLASTER_MAX_GPU_BINARY_BYTES=268435456

# Prompt content is excluded from structured events by default.
LLM_LOG_CONTENT=false
